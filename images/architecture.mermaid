graph TB
    subgraph "Client Layer"
        Client["HTTP Clients\n(curl / browser / SDK)"]:::client
        ProxyClient["Proxy Clients\n(curl / browser / Postman)"]:::client
    end

    subgraph "API Mock Service"
        direction TB
        HTTPServer["HTTP Server\nPort 8080"]:::server
        ProxyServer["Proxy Recorder\nPort 8081"]:::proxy

        subgraph "Mock & Playback"
            ScenarioCtrl["Scenario Controller"]:::controller
            TemplateEngine["Template Engine\n(60+ functions)"]:::core
            DataFactory["Data Factory\n(fuzz generation)"]:::core
        end

        subgraph "Contract Testing"
            ContractCtrl["Contract Controller"]:::controller
            ProducerExec["Producer Executor"]:::testing
            MutationEngine["Mutation Engine\n(null/boundary/security)"]:::testing
            CoverageTracker["Coverage Tracker"]:::testing
            OpenAPIValidator["OpenAPI Schema Validator"]:::testing
        end

        subgraph "OpenAPI Support"
            OAPICtrl["OpenAPI Controller"]:::controller
            OAPIParser["OpenAPI Parser\n(discriminator support)"]:::util
        end
    end

    subgraph "Storage"
        ScenarioRepo["Scenario Repository\n(YAML files)"]:::storage
        FixtureStore["Fixture Store\n(files / images)"]:::storage
        HistoryStore["History Store\n(execution logs)"]:::storage
    end

    subgraph "Upstream Services"
        RealAPI["Real API\n(recorded target)"]:::external
    end

    Client -->|"mock / contract / oapi"| HTTPServer
    ProxyClient -->|"record traffic"| ProxyServer
    ProxyServer -->|"forward & record"| RealAPI

    HTTPServer --> ScenarioCtrl
    HTTPServer --> ContractCtrl
    HTTPServer --> OAPICtrl

    ScenarioCtrl --> TemplateEngine
    TemplateEngine --> DataFactory
    ScenarioCtrl --> ScenarioRepo
    ScenarioCtrl --> FixtureStore

    ContractCtrl --> ProducerExec
    ProducerExec --> MutationEngine
    ProducerExec --> CoverageTracker
    ProducerExec --> OpenAPIValidator
    ProducerExec --> ScenarioRepo
    ProducerExec --> HistoryStore

    OAPICtrl --> OAPIParser
    OAPIParser --> ScenarioRepo

    ProxyServer --> ScenarioRepo

    classDef client fill:#4A90D9,color:#FFFFFF,stroke:#2C5F8A
    classDef server fill:#27AE60,color:#FFFFFF,stroke:#1A7A42
    classDef proxy fill:#F39C12,color:#FFFFFF,stroke:#B7770D
    classDef controller fill:#27AE60,color:#FFFFFF,stroke:#1A7A42
    classDef core fill:#4A90D9,color:#FFFFFF,stroke:#2C5F8A
    classDef testing fill:#8E44AD,color:#FFFFFF,stroke:#6C3483
    classDef util fill:#7F8C8D,color:#FFFFFF,stroke:#566573
    classDef storage fill:#E74C3C,color:#FFFFFF,stroke:#A93226
    classDef external fill:#7F8C8D,color:#FFFFFF,stroke:#566573
